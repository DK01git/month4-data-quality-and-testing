    {
      "description": "opening_date must be on or before today",
      "id": "d79d069d-afb1-4e87-9f4a-5f02daa6ee1d",
      "kwargs": {
        "unexpected_rows_query": "SELECT store_key, store_id, opening_date FROM {batch} WHERE opening_date > CURRENT_DATE"
      },
      "meta": {
        "dimension": "Validity",
        "rationale": "A store cannot have opened in the future"
      },
      "type": "unexpected_rows_expectation"
    },
