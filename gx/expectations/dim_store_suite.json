        "max_value": "2030-12-31",
        "min_value": "1990-01-01"
      },
      "meta": {
        "dimension": "Validity",
        "rationale": "Store opening dates should fall within business horizon (1990-2030)"
      },
      "type": "expect_column_values_to_be_between"
    },
    {
      "description": "No single store_type should account for more than 70% of all stores",
      "id": "d3b19986-8be6-40e2-9ed0-a7c5d6661dc0",
      "kwargs": {
        "unexpected_rows_query": "SELECT store_type, store_count, ratio FROM (  SELECT store_type,          COUNT(*) AS store_count,          CAST(COUNT(*) AS FLOAT) / NULLIF(SUM(COUNT(*)) OVER (), 0) AS ratio   FROM {batch}   GROUP BY store_type) t WHERE ratio > 0.70"
      },
      "meta": {
        "dimension": "Validity",
        "rationale": "Distribution sanity: a healthy retailer has portfolio diversity"
      },
      "type": "unexpected_rows_expectation"
    }
