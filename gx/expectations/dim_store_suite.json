    {
      "description": "store_id must match format 'STR' followed by digits",
      "id": "52c95aeb-b09e-4382-b7e1-774827f2136c",
      "kwargs": {
        "unexpected_rows_query": "SELECT store_key, store_id FROM {batch} WHERE store_id !~ '^STR[0-9]+$'"
      },
      "meta": {
        "dimension": "Validity",
        "rationale": "Business ID convention: 'STR' prefix + numeric suffix"
      },
      "type": "unexpected_rows_expectation"
    },
