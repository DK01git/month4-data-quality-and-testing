    {
      "description": "SCD2 integrity: expiry_date must be >= effective_date",
      "id": "79d0c72c-442e-46a9-9616-1c5d9cddd91b",
      "kwargs": {
        "unexpected_rows_query": "SELECT customer_key, customer_id, effective_date, expiry_date FROM {batch} WHERE expiry_date < effective_date"
      },
      "meta": {
        "dimension": "Consistency",
        "rationale": "Temporal invariant: a record cannot expire before it became effective"
      },
      "type": "unexpected_rows_expectation"
    },
    {
      "description": "SCD2 convention: is_current=TRUE rows carry expiry_date = 9999-12-31",
      "id": "875c02ab-d9cf-4c31-a998-a7f999c17e61",
      "kwargs": {
        "unexpected_rows_query": "SELECT customer_key, customer_id, effective_date, expiry_date FROM {batch} WHERE is_current = TRUE AND expiry_date <> DATE '9999-12-31'"
      },
      "meta": {
        "dimension": "Consistency",
        "rationale": "Industry-standard SCD2 sentinel for open-ended current records"
      },
      "type": "unexpected_rows_expectation"
    },
