      },
      "type": "expect_column_values_to_be_unique"
    },
    {
      "description": "SCD2 integrity: at most one is_current=TRUE row per customer_id",
      "id": "2d7ccf12-90ed-4ca7-9380-9788c3cb4682",
      "kwargs": {
        "unexpected_rows_query": "SELECT customer_id, COUNT(*) AS current_row_count FROM {batch} WHERE is_current = TRUE GROUP BY customer_id HAVING COUNT(*) > 1"
      },
      "meta": {
        "dimension": "Uniqueness",
        "predicted": "FAIL \u2014 D2 injection (10 duplicates)",
        "rationale": "SCD2 compound rule: customer_id has exactly one current row"
      },
      "type": "unexpected_rows_expectation"
    },
    {
      "id": "fe736bb6-b320-493a-b610-24119d936831",
      "kwargs": {
        "column": "email",
        "mostly": 0.99,
        "regex": "^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$"
      },
      "meta": {
        "dimension": "Validity",
        "predicted": "FAIL \u2014 D1 nulls + D3 'n/a' combined exceed 1% tolerance",
        "rationale": "Email must match standard RFC-like regex; D3 injects 'n/a' sentinels"
      },
      "type": "expect_column_values_to_match_regex"
    },
