        "unexpected_rows_query": "SELECT 1 AS anomaly FROM (SELECT        CAST(COUNT(*) FILTER (WHERE is_weekend = TRUE) AS FLOAT)        / NULLIF(COUNT(*), 0) AS weekend_ratio       FROM {batch}) r WHERE r.weekend_ratio NOT BETWEEN 0.25 AND 0.32"
